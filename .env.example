# SteamCMD Proton Server - Environment Variable Reference
# Copy this file to .env and customize for your game

# ==========================================
# REQUIRED VARIABLES
# ==========================================

# Steam App ID of the Windows dedicated server
# Find your game at https://steamdb.info/apps/
STEAM_APP_ID=123456

# Proton App ID (optional, for games where dedicated server differs from game client)
# Used for SteamAppId/compatdata path. Defaults to STEAM_APP_ID if not set.
# Example: For SotF, STEAM_APP_ID=2465200 (server), PROTON_APP_ID=1326470 (game)
PROTON_APP_ID=

# Name of the server executable (relative to game directory)
GAME_EXECUTABLE=Server.exe

# Game preset selector (generic|sons-of-the-forest|valheim|subnautica|dayz|starrupture)
# Leave 'generic' for custom configurations
GAME_CONFIG=generic

# ==========================================
# OPERATION MODE
# ==========================================

# How game files are obtained
# steam    - Download via SteamCMD (default)
# download - Download from URL (requires GAME_DOWNLOAD_URL)
# direct   - Use pre-existing files in GAME_DIR
GAME_MODE=steam

# Download URL for GAME_MODE=download
GAME_DOWNLOAD_URL=

# ==========================================
# STEAM AUTHENTICATION
# ==========================================

# Steam username (default: anonymous for free games)
STEAM_USER=anonymous

# Steam password (only required for non-anonymous login)
STEAM_PASSWORD=

# Steam Guard code (if 2FA enabled on account)
STEAM_GUARD_CODE=

# ==========================================
# SERVER CONFIGURATION
# ==========================================

# Display name in server browser
SERVER_NAME=Dedicated Server

# Server password (empty = public server)
SERVER_PASSWORD=

# Primary game port
GAME_PORT=7777

# Query port for server browser
QUERY_PORT=7778

# Maximum players
MAX_PLAYERS=10

# Game-specific settings
GAME_MODE=Normal
DIFFICULTY=Normal
WORLD_NAME=Dedicated

# Admin password (if applicable)
ADMIN_PASSWORD=

# ==========================================
# GAME-SPECIFIC SETTINGS
# ==========================================

# Sons of the Forest
# GAME_CONFIG=sons-of-the-forest
# STEAM_APP_ID=2465200               # Dedicated Server App ID
# PROTON_APP_ID=1326470              # Game App ID (for Proton prefix)
# GAME_EXECUTABLE=SonsOfTheForestDS.exe
# GAME_PORT=8766
# QUERY_PORT=27016

# Valheim
# GAME_CONFIG=valheim
# STEAM_APP_ID=896660
# GAME_EXECUTABLE=valheim_server.exe
# GAME_PORT=2456

# DayZ
# GAME_CONFIG=dayz
# STEAM_APP_ID=223350
# GAME_EXECUTABLE=DayZServer.exe
# GAME_PORT=2302

# Subnautica
# GAME_CONFIG=subnautica
# STEAM_APP_ID=447530
# GAME_EXECUTABLE=SubnauticaServer.exe
# GAME_PORT=7777

# Star Rupture
# GAME_CONFIG=starrupture
# STEAM_APP_ID=3809400
# GAME_EXECUTABLE=StarRupture/Binaries/Win64/StarRuptureServerEOS-Win64-Shipping.exe
# GAME_PORT=7777
# QUERY_PORT=27015
# SR_SESSION_NAME=StarRuptureServer   # Session/save name
# SR_SAVE_INTERVAL=300                # Auto-save interval in seconds
# SR_START_NEW_GAME=false             # Create new world on first run
# SR_LOAD_SAVED_GAME=true             # Load existing save
# SR_SAVE_GAME_NAME=AutoSave0.sav     # Save file name
# SR_DISABLE_WEB_CONTROL=true         # Disable web control
# SR_DISABLE_WEB_INTERFACE=true       # Disable web interface

# ==========================================
# STEAMCMD SETTINGS
# ==========================================

# Validate game files on update (true|false)
# Set to true if experiencing corruption issues
STEAM_VALIDATE=false

# Beta branch (if applicable)
STEAM_BETA=
STEAM_BETA_PASSWORD=

# ==========================================
# GAME EXECUTION
# ==========================================

# Additional command line arguments for the game
GAME_ARGS=

# Require X virtual framebuffer (for Unity games)
NEEDS_DISPLAY=false

# Xvfb configuration
DISPLAY=:5
XVFB_RESOLUTION=1024x768x16

# ==========================================
# RCON CONFIGURATION
# ==========================================

# Enable RCON (if supported by game)
RCON_ENABLED=false

# RCON port
RCON_PORT=27015

# RCON password
RCON_PASSWORD=

# RCON host (for external RCON clients)
RCON_HOST=127.0.0.1

# ==========================================
# PROTON SETTINGS
# ==========================================

# Disable Steam Runtime (required for Proton)
STEAM_RUNTIME=0

# Proton optimization flags (don't change these)
PROTON_NO_FSYNC=1
PROTON_NO_ESYNC=1

# Custom Proton path (auto-detected by default)
# PROTONPATH=/root/.steam/steam/compatibilitytools.d/GE-Proton9-15

# ==========================================
# PATHS
# ==========================================

# Game installation directory
GAME_DIR=/game

# Persistent data directory (saves, configs, backups)
DATA_DIR=/data

# Backup directory
BACKUP_DIR=/data/backups

# Steam compatibility data path
STEAM_COMPAT_DATA_PATH=

# ==========================================
# BACKUP SETTINGS
# ==========================================

# Number of backups to retain (days)
BACKUP_RETENTION=7

# Backup before update
BACKUP_BEFORE_UPDATE=false

# ==========================================
# LOGGING
# ==========================================

# Maximum log file size before rotation
LOG_MAX_SIZE=100M

# Number of rotated logs to keep
LOG_RETENTION=5

# Enable debug logging
DEBUG=false

# ==========================================
# RESOURCES (for docker-compose deploy)
# ==========================================

# CPU limit
CPU_LIMIT=4

# Memory limit
MEMORY_LIMIT=8G

# CPU reservation
CPU_RESERVATION=2

# Memory reservation
MEMORY_RESERVATION=4G
